{
  "name": "clipsanitizer",
  "version": "1.1.0",
  "description": "Sanitizes clipboard text for EHR compatibility",
  "main": "dist/main/main.js",
  "build": {
    "appId": "gov.mil.clipsanitizer",
    "productName": "ClipSanitizer",
    "copyright": "See LICENSE",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/main/**/*",
      "dist/renderer/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/main/main.js"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ClipSanitizer",
      "deleteAppDataOnUninstall": true,
      "include": "build/installer.nsh"
    },
    "portable": {
      "artifactName": "ClipSanitizer-portable-${version}-${arch}.exe"
    },
    "publish": null
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"electron .\"",
    "build": "vite build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "vitest run tests/smoke.test.js",
    "build:web": "vite build --config vite.config.web.js && npm run build:copy-web",
    "build:copy-web": "node scripts/copy-web-artifact.js"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "mammoth": "^1.8.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-singlefile": "^2.3.2",
    "vitest": "^2.0.0"
  }
}
